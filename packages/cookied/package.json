{
	"name": "cookied",
	"description": "PostgreSQL-backed authentication for Node.js-based web applications",
	"version": "0.2.3",
	"scripts": {
		"build": "./node_modules/.bin/tsc",
		"test": "../../dev/test-schema && ./node_modules/.bin/vitest run && ./node_modules/.bin/tsc --target esnext --moduleResolution node --noEmit tests/*.ts && ./node_modules/.bin/eslint .",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write ."
	},
	"type": "module",
	"exports": {
		"./*": "./dist/*"
	},
	"typesVersions": {
		"*": {
			"*": [
				"dist/*"
			]
		}
	},
	"dependencies": {
		"ayy": "^4.1.0",
		"hash-wasm": "^4.12.0",
		"postgres": "^3.4.9"
	},
	"peerDependencies": {
		"@logtape/logtape": "^2.2.1",
		"@sveltejs/kit": "^2.0.5"
	},
	"devDependencies": {
		"eslint": "^10.6.0",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vitest": "4.1.9"
	}
}
